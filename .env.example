# ==========================================
# noKeyCloud Configuration
# ==========================================

# 1. Network & Domain
# For local network testing, leave as 'localhost'.
# For public servers, enter your domain (e.g., cloud.mywebsite.com) to get automatic Let's Encrypt SSL.
DOMAIN_NAME=localhost

# 2. Security (CRITICAL)
# Generate a random string of at least 32 characters. Do not share this!
# Example: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_A_VERY_LONG_SECURE_RANDOM_STRING_MINIMUM_32_CHARS

# 3. Database Credentials
POSTGRES_USER=nokeycloud_user
POSTGRES_PASSWORD=nokeycloud_super_secret_password
POSTGRES_DB=nokeycloud_db